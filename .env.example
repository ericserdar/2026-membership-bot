# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_server_id
DISCORD_VERIFY_CHANNEL_ID=the_channel_id_where_verify_button_lives

# Role IDs (right-click role in Discord → Copy ID)
DISCORD_ROLE_GOLD_ID=
DISCORD_ROLE_SILVER_ID=
DISCORD_ROLE_INSIDER_ID=
DISCORD_ROLE_UNSUBSCRIBED_ID=

# ── MemberPress ────────────────────────────────────────────────────────────────
MEMBERPRESS_API_KEY=your_memberpress_api_key
MEMBERPRESS_API_USERNAME=your_wordpress_admin_username
MEMBERPRESS_BASE_URL=https://cougconnect.com

# Membership post IDs — find in WP admin → MemberPress → Memberships → hover row → see ID in URL
# Comma-separated, no spaces
MEMBERPRESS_TIER_GOLD_IDS=        # Gold (monthly), Gold Annual
MEMBERPRESS_TIER_SILVER_IDS=      # Silver (monthly), Silver Annual
MEMBERPRESS_TIER_INSIDER_IDS=     # Insider (monthly), Basic Annual

# ── Security ───────────────────────────────────────────────────────────────────
# Random string shared between the WordPress page and this bot
BOT_VERIFY_SECRET=generate_a_random_secret_here

# HMAC secret configured in MemberPress → Settings → Developer Tools → Webhooks
MEMBERPRESS_WEBHOOK_SECRET=generate_another_random_secret_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
BOT_PUBLIC_URL=https://your-app.railway.app
